# Copy to .env and adjust. All variables are optional; defaults run a local,
# zero-setup configuration (SQLite + stub classifier + template reporter).

# --- storage ---
INSPECTOR_DATABASE_URL=sqlite:///./inspector.db
# Postgres (matches docker-compose):
# INSPECTOR_DATABASE_URL=postgresql+psycopg://inspector:inspector@localhost:5432/inspector

# --- classifier: stub | torch ---
INSPECTOR_CLASSIFIER_BACKEND=stub
INSPECTOR_MODEL_REPO=Alexissmt/solar-defect-inspector
INSPECTOR_MODEL_FILENAME=solar_model.pth

# --- reporter: template | groq ---
INSPECTOR_REPORTER_BACKEND=template
# INSPECTOR_GROQ_API_KEY=gsk_...
INSPECTOR_GROQ_MODEL=llama-3.3-70b-versatile

# --- batch pipeline storage: local | gcs ---
INSPECTOR_STORAGE_BACKEND=local
INSPECTOR_STORAGE_ROOT=./data/incoming
# INSPECTOR_GCS_BUCKET=my-inspection-bucket
# INSPECTOR_GCS_PREFIX=incoming/
